<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMAUI.Views.RegistrarVehiculoPage"
             Title="RegistrarVehiculoPage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Entry Placeholder="Placas" />
            <Picker Title="Marca" x:Name="pickerMarca"/>
            <Entry Placeholder="Modelo" />
            <Entry Placeholder="Año" Keyboard="Numeric"/>

            <Button Text="Guardar" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>