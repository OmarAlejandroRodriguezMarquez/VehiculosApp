             x:Class="VehiculosMAUI.Views.ReporteFallaPage"
             Title="ReporteFallaPage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <DatePicker />

            <Editor Placeholder="Descripción del problema"
                    AutoSize="TextChanges"
                    HeightRequest="120"/>

            <Button Text="Guardar" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>