<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMAUI.Views.ListaVehiculosPage"
             Title="ListaVehiculosPage">
    <VerticalStackLayout Padding="10">
        <Button Text="Agregar Vehículo" HorizontalOptions="End" Margin="0,0,0,10" Clicked="Button_Clicked"/>

        <SearchBar Placeholder="Buscar vehículo..." />

        <CollectionView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="ABC123 - Nissan Sentra" FontAttributes="Bold"/>
                            <Button Text="Ver Detalle" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>