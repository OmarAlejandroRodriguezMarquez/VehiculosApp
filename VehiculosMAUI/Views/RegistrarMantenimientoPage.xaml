<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VehiculosMAUI.Views.RegistrarMantenimientoPage"
             Title="RegistrarMantenimientoPage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <DatePicker />

            <Picker Title="Tipo de Servicio" />

            <Entry Placeholder="Costo" Keyboard="Numeric"/>
            <Entry Placeholder="Kilometraje" Keyboard="Numeric"/>

            <Button Text="Guardar" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>